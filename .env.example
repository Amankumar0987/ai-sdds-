# AI-SDDS API — पर्यावरण वेरिएबल (Environment Variables)
# इस फ़ाइल को .env में कॉपी करें और असली मान भरें — .env को कभी commit न करें।

# Comma-separated list of valid API keys. Empty = server auto-generates
# one at startup and logs it once (see startup log).
AI_SDDS_API_KEYS=

# "false" से auth पूरी तरह बंद हो जाता है — केवल local dev के लिए।
AI_SDDS_REQUIRE_API_KEY=true

# Comma-separated list of allowed browser origins for CORS.
# ध्यान दें: origin में कभी path नहीं होता (scheme://host[:port] तक ही)।
# उदाहरण: chrome-extension://abcdefghijklmnop,https://yourapp.com
AI_SDDS_ALLOWED_ORIGINS=

# slowapi rate-limit string, e.g. "30/minute", "100/hour"
AI_SDDS_RATE_LIMIT=30/minute

# Windows-only: pytesseract को tesseract.exe का पूरा रास्ता बताएँ।
# Linux/Mac/Docker पर खाली छोड़ें — वहाँ PATH से अपने-आप मिल जाता है।
AI_SDDS_TESSERACT_CMD=C:\Program Files\Tesseract-OCR
